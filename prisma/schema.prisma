generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum DeviceTokenType {
  APNS
  APNS_VOIP
  FCM
}

enum ChatType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  SYSTEM
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  ACCEPTED
  DECLINED
  MISSED
}

model User {
  id          String    @id @default(uuid())
  phone       String    @unique
  username    String?   @unique
  displayName String
  avatarUrl   String?
  bio         String?
  lastSeen    DateTime?
  createdAt   DateTime  @default(now())

  initiatedCalls  CallLog[]    @relation("Initiator")
  receivedCalls   CallLog[]    @relation("Target")
  contacts        Contact[]    @relation("ContactOwner")
  contactOf       Contact[]    @relation("ContactEntry")
  blockedUsers    Block[]      @relation("Blocker")
  blockedBy       Block[]      @relation("Blocked")
  chatMemberships ChatMember[]
  sentMessages    Message[]
  messageReads    MessageRead[]
  deviceTokens    DeviceToken[]
}

model Contact {
  ownerId   String
  contactId String
  createdAt DateTime @default(now())

  owner   User @relation("ContactOwner", fields: [ownerId],   references: [id])
  contact User @relation("ContactEntry", fields: [contactId], references: [id])

  @@id([ownerId, contactId])
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}

model DeviceToken {
  id        String          @id @default(uuid())
  userId    String
  token     String          @unique
  type      DeviceTokenType
  platform  DevicePlatform
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Chat {
  id        String   @id @default(uuid())
  type      ChatType
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())

  members  ChatMember[]
  messages Message[]
}

model ChatMember {
  chatId     String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
}

model Message {
  id        String      @id @default(uuid())
  chatId    String
  senderId  String
  type      MessageType @default(TEXT)
  content   String?
  replyToId String?
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime    @default(now())

  chat    Chat          @relation(fields: [chatId], references: [id])
  sender  User          @relation(fields: [senderId], references: [id])
  replyTo Message?      @relation("ReplyTo", fields: [replyToId], references: [id])
  replies Message[]     @relation("ReplyTo")
  reads   MessageRead[]

  @@index([chatId, createdAt(sort: Desc)])
}

model MessageRead {
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
}

model CallLog {
  id          String     @id @default(uuid())
  initiatorId String
  targetId    String
  type        CallType
  status      CallStatus
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime   @default(now())

  initiator User @relation("Initiator", fields: [initiatorId], references: [id])
  target    User @relation("Target",    fields: [targetId],    references: [id])
}
